# RAG backend (Spring Boot). Used when running locally; in Docker, compose uses db/.env + this file.
# Copy to .env or run docker/scripts/create-env-rag-service.sh from repo root.

# Base images for build (rag-service/Dockerfile)
RAG_JAVA_JDK_BASE_IMAGE=eclipse-temurin:21-jdk
RAG_JAVA_JRE_BASE_IMAGE=eclipse-temurin:21-jre-alpine

# Server (container: SERVER_PORT; host port: BACKEND_PORT in compose)
SERVER_PORT=9000
BACKEND_PORT=9000

# backend-dev (Dockerfile.dev) only — faster restarts if target/classes exists (see scripts/docker-dev-entrypoint.sh)
# RAG_DEV_FORCE_INITIAL_COMPILE=1
# RAG_DEV_SKIP_INITIAL_COMPILE=1
# RAG_DEV_POLL_INTERVAL=2

# Database (same credentials as db/.env when using local Postgres or compose)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/vectordb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Ollama (LLM and embeddings).
# - mvn spring-boot:run on the host: http://localhost:11434
# - backend-dev in Docker without an Ollama container (recommended when using host GPU):
#     http://host.docker.internal:11434  (do NOT use localhost inside the container)
# - Docker with docker-compose.yml --profile ollama (--gpu / --ollama): http://ollama:11434
# See ./docker/scripts/up.sh dev --rag --obs --classifier
# Primary Ollama HTTP API for Docker and local runs. In containers use host.docker.internal, ollama:11434 (with profile ollama), or a LAN URL — not localhost unless the server listens inside the same network namespace.
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Spring AI property; if unset in Compose, it falls back to OLLAMA_BASE_URL (see docker-compose.yml / compose.dev.yml).
SPRING_AI_OLLAMA_BASE_URL=http://host.docker.internal:11434
SPRING_AI_OLLAMA_CHAT_MODEL=gemma3:4b
SPRING_AI_OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# Classifier service (HTTP API)
RAG_CLASSIFIER_SERVICE_URL=http://localhost:8000
RAG_CLASSIFIER_SERVICE_TIMEOUT_MS=5000
RAG_CLASSIFIER_MODEL_ID=default

# Optional: align chat config resolution with POST /config/preview (default off).
# RAG_CONFIG_V2_ENABLED=true

# -----------------------------------------------------------------------------
# Dev-only seeded users (profile "dev" only; NEVER enable in production)
# -----------------------------------------------------------------------------
# When the backend runs with Spring profile "dev", it seeds two accounts so the UI can be tested quickly:
# - Admin: can access /api/admin/*
# - User:  normal role (non-admin)
#
# Override these credentials in rag-service/.env if you don't want the defaults.
# Defaults (if unset): admin@dev.local / dev  and  user@dev.local / dev
#
# RAG_DEV_SEED_ADMIN_EMAIL=admin@dev.local
# RAG_DEV_SEED_ADMIN_PASSWORD=dev
# RAG_DEV_SEED_ADMIN_NAME=Dev Admin
# RAG_DEV_SEED_USER_EMAIL=user@dev.local
# RAG_DEV_SEED_USER_PASSWORD=dev
# RAG_DEV_SEED_USER_NAME=Dev User

# -----------------------------------------------------------------------------
# Prod initial admin bootstrap (profile "prod" only)
# -----------------------------------------------------------------------------
# If the database has NO admin users yet, the application will require these to be set and will create
# the first ADMIN user on startup. If an admin already exists, these are ignored (safe for upgrades).
#
# RAG_BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# RAG_BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password
# RAG_BOOTSTRAP_ADMIN_NAME=Admin

# DB schema management
# - DEV_LOCAL: update (allow Hibernate to evolve schema)
# - PROD_LOCAL/PROD: none (use Flyway migrations; no ddl-auto updates)
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# -----------------------------------------------------------------------------
# Authentication / account lifecycle (email verification, password reset, OAuth)
# -----------------------------------------------------------------------------
# These are feature flags and settings for `/api/auth/*`.
#
# Email confirmation:
# - When enabled, `/api/auth/register` returns HTTP 202 and the user must confirm the email before login.
# - Confirmation emails are queued into `mail_outbox` when `rag.auth.mail.enabled=true` (a separate dispatcher may deliver).
#
# RAG_AUTH_EMAIL_CONFIRMATION_ENABLED=true
# RAG_AUTH_EMAIL_CONFIRMATION_TOKEN_TTL_SECONDS=3600
#
# Password reset:
# - `/api/auth/forgot-password` is anti-enumeration (always returns 200).
# - Reset emails are queued into `mail_outbox` when `rag.auth.mail.enabled=true`.
#
# RAG_AUTH_PASSWORD_RESET_ENABLED=true
# RAG_AUTH_PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
#
# Mail outbox:
# RAG_AUTH_MAIL_ENABLED=false
# RAG_AUTH_MAIL_FROM=no-reply@local.test
#
# UI/base URLs used when generating email links and OAuth redirect URIs:
# RAG_AUTH_WEBAPP_BASE_URL=http://localhost:3000
# RAG_AUTH_BACKEND_BASE_URL=http://localhost:9000
#
# OAuth (Google):
# RAG_AUTH_OAUTH_ENABLED=false
# RAG_AUTH_OAUTH_GOOGLE_CLIENT_ID=
# RAG_AUTH_OAUTH_GOOGLE_CLIENT_SECRET=
# RAG_AUTH_OAUTH_GOOGLE_ISSUER=https://accounts.google.com
# RAG_AUTH_OAUTH_GOOGLE_REDIRECT_PATH=/api/auth/oauth/google/callback

# Account export ZIP (GDPR-style): directory on disk, TTL in hours, cleanup sweep interval (ms).
# RAG_ACCOUNT_EXPORT_STORAGE_DIR=/tmp/rag-account-export
# RAG_ACCOUNT_EXPORT_TTL_HOURS=24
# RAG_ACCOUNT_CLEANUP_INTERVAL_MS=3600000

# Optional: OpenTelemetry — for `mvn spring-boot:run` on the host with collector on localhost:4318.
# In Docker, compose.obs.yml / compose.rag-dev-obs.yml FIXES http://otel-collector:4318 and MANAGEMENT_OTLP_* (precedence
# over this file). If you leave localhost here and for some reason the override of the compose is not applied, the traces go to
# the wrong container and Jaeger remains empty.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=rag-backend
# Do not set SPRING_PROFILES_ACTIVE here for Docker — it is fixed by compose (e.g. infra or dev,infra).
