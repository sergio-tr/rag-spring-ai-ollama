# Static OpenSSL SAN reference (defaults for development + university production).
# Runtime generation uses generate-self-signed-cert.sh (dynamic [alt_names] from TLS_CERT_* env).
# Edit this file only as documentation; the entrypoint script builds the active config at startup.
[req]
default_bits = 4096
prompt = no
default_md = sha256
x509_extensions = v3_req
distinguished_name = dn

[dn]
C = ES
ST = Asturias
L = Oviedo
O = University of Oviedo
OU = RAG System
CN = localhost

[v3_req]
subjectAltName = @alt_names
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth

[alt_names]
DNS.1 = localhost
DNS.2 = host.docker.internal
DNS.3 = uniovi.es
DNS.4 = www.uniovi.es
DNS.5 = rag.uniovi.es
IP.1 = 127.0.0.1
IP.2 = 156.35.95.27
