# =============================================================================
# Production-oriented environment index (RAG Spring AI Ollama)
# =============================================================================
# Copy per-component files from each module's .env.example, then replace placeholders.
# Never commit real .env files or secrets.
#
#   db/.env
#   rag-service/.env
#   webapp/.env
#   classifier-service/.env
#   observability/.env   (required when observability profile is enabled)
#
# Production deploy (self-hosted runner on application server):
#   ./docker/scripts/up.sh prod --server --obs --obs-private --no-env-prompt
#
# Application server:  156.35.95.27
# Model-serving server: 156.35.160.78 (LiteLLM → Ollama; backend must not call Ollama directly)
# =============================================================================

# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
PRODUCTION_BASE_URL=https://CHANGE_ME.example
FRONTEND_PUBLIC_URL=https://CHANGE_ME.example
BACKEND_PUBLIC_URL=https://CHANGE_ME.example
DEPLOY_DIR=/opt/rag-spring-ai-ollama
DEPLOY_HEALTH_URL=http://127.0.0.1/actuator/health/liveness
GITHUB_PAGES_URL=https://sergio-tr.github.io/rag-spring-ai-ollama/

# -----------------------------------------------------------------------------
# Backend security
# -----------------------------------------------------------------------------
RAG_JWT_SECRET=CHANGE_ME_MIN_32_CHARACTERS
SPRING_PROFILES_ACTIVE=prod,docker,infra
RAG_CORS_ALLOWED_ORIGINS=https://CHANGE_ME.example
RAG_API_PRODUCT_BASE_PATH=/api/v5

# -----------------------------------------------------------------------------
# Database (see db/.env)
# -----------------------------------------------------------------------------
POSTGRES_DB=vectordb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_MONITOR_USER=postgres_exporter
POSTGRES_MONITOR_PASSWORD=CHANGE_ME

# -----------------------------------------------------------------------------
# LiteLLM / model serving (PRODUCTION — no direct Ollama on application server)
# -----------------------------------------------------------------------------
RAG_LLM_DEFAULT_PROVIDER=OPENAI_COMPATIBLE
RAG_LLM_DEFAULT_CHAT_PROVIDER=OPENAI_COMPATIBLE
RAG_LLM_DEFAULT_EMBEDDING_PROVIDER=OPENAI_COMPATIBLE
LITELLM_BASE_URL=http://156.35.160.78:4000
OPENAI_COMPATIBLE_API_KEY=CHANGE_ME
LITELLM_CHAT_MODEL=CHANGE_ME
LITELLM_EMBEDDING_MODEL=CHANGE_ME
# LITELLM_AVAILABLE_CHAT_MODELS=...
# LITELLM_AVAILABLE_EMBEDDING_MODELS=...

# -----------------------------------------------------------------------------
# Google OAuth (backend-owned; see rag-service/.env.example)
# -----------------------------------------------------------------------------
RAG_AUTH_OAUTH_ENABLED=true
RAG_AUTH_OAUTH_GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
RAG_AUTH_OAUTH_GOOGLE_CLIENT_SECRET=CHANGE_ME
RAG_AUTH_WEBAPP_BASE_URL=https://CHANGE_ME.example
RAG_AUTH_BACKEND_BASE_URL=https://CHANGE_ME.example
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=true

# -----------------------------------------------------------------------------
# SMTP / email delivery (production — not Mailpit)
# -----------------------------------------------------------------------------
RAG_AUTH_MAIL_ENABLED=true
RAG_AUTH_MAIL_DELIVERY_MODE=smtp
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=support.rag@gmail.es
SPRING_MAIL_PASSWORD=CHANGE_ME_APP_PASSWORD
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
RAG_AUTH_MAIL_FROM=support.rag@gmail.es
SUPPORT_EMAIL=support.rag@gmail.es

# -----------------------------------------------------------------------------
# Legal documents
# -----------------------------------------------------------------------------
RAG_AUTH_LEGAL_REQUIRED=true
RAG_AUTH_LEGAL_PRIVACY_POLICY_VERSION=2026-06
RAG_AUTH_LEGAL_TERMS_VERSION=2026-06
NEXT_PUBLIC_LEGAL_PRIVACY_VERSION=2026-06
NEXT_PUBLIC_LEGAL_TERMS_VERSION=2026-06
# Privacy Policy: {FRONTEND_PUBLIC_URL}/en/privacy-policy
# Terms of Use:      {FRONTEND_PUBLIC_URL}/en/terms

# -----------------------------------------------------------------------------
# Observability (see observability/.env)
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
OTEL_SERVICE_NAME=rag-backend

# -----------------------------------------------------------------------------
# Docker Compose / deployment (GitHub repository variables)
# -----------------------------------------------------------------------------
# DEPLOY_DIR and DEPLOY_HEALTH_URL are consumed by .github/workflows/deploy.yml
REVERSE_PROXY_HTTP_PORT=80
REVERSE_PROXY_HTTPS_PORT=8443
# REVERSE_PROXY_ENFORCE_HTTPS=1

# -----------------------------------------------------------------------------
# Frontend public variables (see webapp/.env)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_RAG_API_PREFIX=/api/v5
NEXT_PUBLIC_TIMEZONE=Europe/Madrid

# -----------------------------------------------------------------------------
# Classifier service (internal only in production; see classifier-service/.env)
# -----------------------------------------------------------------------------
CLASSIFIER_SERVICE_PORT=8000

# -----------------------------------------------------------------------------
# Document binary storage (Docker Compose)
# -----------------------------------------------------------------------------
# Named volume rag_binary_storage is mounted at RAG_STORAGE_ROOT for backend and backend-dev.
# Required for durable evaluation corpus binaries across container restarts (not /tmp).
RAG_STORAGE_ROOT=/var/lib/rag/storage

# -----------------------------------------------------------------------------
# Evaluation / reproducibility (do not change for thesis evidence)
# -----------------------------------------------------------------------------
# Lab and evaluation settings remain in rag-service/.env per existing conventions.
# Live corpus/project context: docker/scripts/final-readiness-preflight.mjs --write-context

# -----------------------------------------------------------------------------
# Development-only (DO NOT USE IN PRODUCTION)
# -----------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# SPRING_AI_OLLAMA_BASE_URL=http://host.docker.internal:11434
# SPRING_MAIL_HOST=mailpit
# RAG_DEV_SEED_ADMIN_EMAIL=admin@dev.local
# Mailpit: ./docker/scripts/up.sh dev --mail (profile dev-mail only)
