# =============================================================================
# Webapp environment (browser, Next.js, and Docker Compose interpolation)
# Copy to .env: ./docker/scripts/create-env-webapp.sh
# Compose reads this file via --env-file for WEBAPP_* port mappings.
# =============================================================================

# --- Docker Compose: publish webapp on the host (HTTP) ---
# Host port; Grafana defaults to host 3030 in observability/.env — avoid :3000 (Next.js dev + legacy OAuth default).
WEBAPP_HTTP_PORT=80

# Port Next.js listens on *inside* the container (must match nginx WEBAPP_INTERNAL_PORT / reverse-proxy).
WEBAPP_CONTAINER_PORT=3000

# --- Browser / Next public (baked at `docker build` if passed as build-arg; runtime below can override) ---
# Spring Boot API for local dev without reverse-proxy (typical Docker backend: 9000).
# Use empty string when the UI and API share the same origin (nginx reverse-proxy in front).
# - Without reverse-proxy: set to http://127.0.0.1:9000
# - With reverse-proxy (recommended; prod-like): leave empty so the browser calls /api/v5/* on the same origin.
# With --proxy: leave empty. Without --proxy: http://127.0.0.1:9000
NEXT_PUBLIC_API_BASE_URL=

# Must match Spring rag.api.product-base-path / RAG_API_PRODUCT_BASE_PATH.
NEXT_PUBLIC_RAG_API_PREFIX=/api/v5

# --- API contract (webapp) ---
# Product routes use NEXT_PUBLIC_RAG_API_PREFIX + path, e.g. GET {prefix}/projects, GET {prefix}/config/schema.
# Auth resource calls use NEXT_PUBLIC_RAG_API_PREFIX + /auth/* (default /api/v5/auth/*). See webapp/README.md.

# IANA timezone for next-intl (required in production; avoids ENVIRONMENT_FALLBACK).
NEXT_PUBLIC_TIMEZONE=UTC

# HttpOnly cookie names (BFF / middleware).
NEXT_PUBLIC_AUTH_ACCESS_COOKIE_NAME=rag_access_token
NEXT_PUBLIC_AUTH_REFRESH_COOKIE_NAME=rag_refresh_token

# OAuth entrypoints (optional): if empty, OAuth buttons may be hidden by the UI.
NEXT_PUBLIC_OAUTH_GOOGLE_ENABLED=true
# Rebuild the webapp (or restart `npm run dev`) after changing these — values are embedded at build time.
NEXT_PUBLIC_LEGAL_PRIVACY_VERSION=2026-06-21
NEXT_PUBLIC_LEGAL_TERMS_VERSION=2026-06-21

# --- Optional: local `npm run dev` only (ignored by Docker if PORT is set via compose) ---
# PORT=3000

# --- Dev reverse-proxy (nginx) host ports (docker/compose.dev-proxy.yml) ---
# If you enable the dev reverse-proxy (./docker/scripts/up.sh dev --rag --proxy ...), nginx binds to this host port.
# Use 8080 if port 80 is already taken on the host.
# REVERSE_PROXY_DEV_HTTP_PORT=8080
# Dev HTTPS entrypoint (self-signed certificate generated in reverse-proxy image).
# REVERSE_PROXY_DEV_HTTPS_PORT=8444
# REVERSE_PROXY_ENFORCE_HTTPS=1

# --- Prod-local reverse-proxy (nginx) host ports (docker/compose.prod.yml) ---
# In prod-local, reverse-proxy is always used and is the ONLY public entrypoint.
# Production server (--server on up.sh): same reverse-proxy entry; backend/classifier host ports omitted.
# Change these if the default host ports are already taken.
# REVERSE_PROXY_HTTP_PORT=80
# REVERSE_PROXY_HTTPS_PORT=8443
# In prod-like mode, force HTTP -> HTTPS redirect at reverse-proxy.
# REVERSE_PROXY_ENFORCE_HTTPS=1

# Reverse-proxy API and upload safety defaults.
# API_CLIENT_MAX_BODY_SIZE=50m
# API_PROXY_CONNECT_TIMEOUT=10s
# API_PROXY_SEND_TIMEOUT=180s
# API_PROXY_READ_TIMEOUT=180s

# Optional: bypass middleware auth (tests only — never in production).
# NEXT_PUBLIC_SKIP_AUTH=true

# Playwright / fullstack: non-Secure cookies when NODE_ENV=production.
# E2E_ALLOW_INSECURE_COOKIES=true

# E2E preflight (demo reverse-proxy — see scripts/e2e-bases.mjs):
# PLAYWRIGHT_BASE_URL=https://127.0.0.1:8444
# E2E_PUBLIC_BASE_URL=https://127.0.0.1:8444
# API_BASE_URL=https://127.0.0.1:8444
# E2E_BACKEND_HEALTH_URL=https://127.0.0.1:8444
# PLAYWRIGHT_SKIP_WEBSERVER=1
# PLAYWRIGHT_IGNORE_HTTPS_ERRORS=1
# NODE_TLS_REJECT_UNAUTHORIZED=0
# CI/direct backend: API_BASE_URL=http://127.0.0.1:9000 E2E_BACKEND_HEALTH_URL=http://127.0.0.1:9000 E2E_WEB_HEALTH_URL=http://127.0.0.1:3000
