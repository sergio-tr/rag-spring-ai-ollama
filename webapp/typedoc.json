{
  "$schema": "https://typedoc.org/schema.json",
  "tsconfig": "./tsconfig.json",
  "entryPoints": [
    "src/app",
    "src/components",
    "src/features",
    "src/hooks",
    "src/store",
    "src/lib",
    "src/types"
  ],
  "entryPointStrategy": "expand",
  "out": "docs/api",
  "readme": "none",
  "excludeInternal": true,
  "skipErrorChecking": true,
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "**/e2e/**",
    "**/docs/api/**",
    "**/.next/**",
    "**/node_modules/**"
  ]
}
