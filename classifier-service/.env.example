# Classifier service (FastAPI). Used when running locally; in Docker, compose uses these for build and run.
# Copy to .env or run scripts/create-env-classifier-service.sh from repo root.

# Base image for build (classifier-service/Dockerfile)
CLASSIFIER_PYTHON_BASE_IMAGE=nvidia/cuda:12.5.1-cudnn-runtime-ubuntu22.04

# Server (container: PORT; host port: CLASSIFIER_SERVICE_PORT in compose)
PORT=8000
CLASSIFIER_SERVICE_PORT=8000

# Paths (inside container: MODELS_DIR, DATA_DIR; locally use relative paths)
MODELS_DIR=/app/models
DATA_DIR=/app/data

# Optional: override default model paths (defaults: sklearn model.joblib or Keras model.keras + labels.txt)
# MODEL_PATH=models/default/model.joblib
# LABELS_PATH=models/default/labels.txt

# Optional: default model id and display name for GET /models
# DEFAULT_MODEL_ID=default
# DEFAULT_MODEL_NAME=default

# Optional: OpenTelemetry (when using observability stack)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=classifier-service
