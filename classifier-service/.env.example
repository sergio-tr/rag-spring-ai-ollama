# Classifier service (FastAPI). Used when running locally; in Docker, compose sets PORT and MODELS_DIR.
# Copy to .env or run scripts/create-env-classifier-service.sh from repo root.

# Server
PORT=8000

# Paths (inside container use /app/models and /app/data; locally use relative paths)
MODELS_DIR=models
DATA_DIR=data

# Optional: override default model paths (defaults: MODELS_DIR/default/model.keras and labels.txt)
# MODEL_PATH=models/default/model.keras
# LABELS_PATH=models/default/labels.txt

# Optional: default model id and display name for GET /models
# DEFAULT_MODEL_ID=default
# DEFAULT_MODEL_NAME=default

# Optional: OpenTelemetry (when using observability stack)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=classifier-service
