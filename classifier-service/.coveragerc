[run]
# Source directories to measure (package lives under ./app when cwd is classifier-service/)
source = app

# Do not use relative_files=true here: it flattens Cobertura filenames (__init__.py at root) and SonarCloud
# (project base = repo root, sonar.sources=classifier-service/app) cannot match coverage entries.

# Omit files that don't need coverage measurement
omit =
    tests/*
    tests/**/*
    venv/*
    */__pycache__/*
    */site-packages/*

# Enable branch coverage (more accurate; SonarCloud uses it)
branch = true

[report]
# Minimum coverage to pass (mirrors SonarCloud quality gate)
fail_under = 80

# Exclude lines from coverage measurement
exclude_lines =
    # Standard pragmas
    pragma: no cover
    # Abstract method bodies
    raise NotImplementedError
    # Defensive imports
    if TYPE_CHECKING:
    # Unreachable else on exhaustive match
    assert False

[xml]
# Path written by `pytest --cov-report=xml` — matches sonar-project.properties
output = coverage.xml

[html]
# Local HTML report (not sent to SonarCloud; for local inspection)
directory = htmlcov
