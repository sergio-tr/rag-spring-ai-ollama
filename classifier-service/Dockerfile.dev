# Development Dockerfile for classifier-service (sklearn runtime by default; GPU extras optional).
ARG BASE_IMAGE=python:3.10-slim-bookworm
FROM ${BASE_IMAGE}

ARG PORT=8000
ARG MODELS_DIR=/app/models
ARG DATA_DIR=/app/data
ARG INSTALL_GPU_EXTRAS=0
ENV PORT=${PORT} MODELS_DIR=${MODELS_DIR} DATA_DIR=${DATA_DIR}

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends curl libgomp1 \
  && rm -rf /var/lib/apt/lists/*

COPY requirements-runtime.txt requirements-gpu.txt ./
RUN python -m pip install --no-cache-dir --upgrade pip setuptools wheel \
  && python -m pip install --no-cache-dir -r requirements-runtime.txt \
  && if [ "$INSTALL_GPU_EXTRAS" = "1" ]; then python -m pip install --no-cache-dir -r requirements-gpu.txt; fi

COPY models/ ./models/
COPY data/ ./data/

EXPOSE ${PORT}

CMD ["sh", "-c", "python -m uvicorn uvicorn_entry:app --host 0.0.0.0 --port ${PORT} --reload --reload-dir app"]
