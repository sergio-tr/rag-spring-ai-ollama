# Development Dockerfile for classifier-service.
# Differences from production Dockerfile:
#   - Uses uvicorn --reload --reload-dir app (hot-reload on source changes)
#   - Does NOT copy app/ source (mounted as bind volume by compose.dev.yml)
#   - Installs curl for dev healthcheck
#
# Production image: use Dockerfile (no --reload, no curl, smaller layer).
ARG BASE_IMAGE=python:3.11-slim
FROM ${BASE_IMAGE}

ARG PORT=8000
ARG MODELS_DIR=/app/models
ARG DATA_DIR=/app/data
ENV PORT=${PORT} MODELS_DIR=${MODELS_DIR} DATA_DIR=${DATA_DIR}

WORKDIR /app

# curl for healthcheck in dev
RUN apt-get update && apt-get install -y --no-install-recommends curl && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Models and data are baked in (rarely change; source is mounted via volume)
COPY models/ ./models/
COPY data/ ./data/

# app/ and main.py are mounted as bind volumes by compose.dev.yml — not copied here.
# On first start, Docker will overlay the volume on top of this empty /app/app path.

EXPOSE ${PORT}

# --reload watches app/ for changes; --reload-dir prevents watching models/ and data/
CMD ["sh", "-c", "uvicorn main:app --host 0.0.0.0 --port ${PORT} --reload --reload-dir app"]
