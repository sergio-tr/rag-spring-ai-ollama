# Ollama container (docker-compose.yml, profile ollama). Set OLLAMA_BASE_URL=http://ollama:11434 for Spring when using this profile.
# Copy to .env or run scripts/create-env-ollama.sh from repo root.
# See ollama/README.md

# Base image for build (ollama/Dockerfile)
OLLAMA_BASE_IMAGE=ollama/ollama:latest

# Host port when running with profile ollama
OLLAMA_PORT=11434
