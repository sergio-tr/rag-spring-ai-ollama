# Ollama container (used with docker compose.ollama-local-gpu.yml).
# Copy to .env or run scripts/create-env-ollama.sh from repo root.
# See ollama/README.md

# Base image for build (ollama/Dockerfile)
OLLAMA_BASE_IMAGE=ollama/ollama:latest

# Host port when running with compose.ollama-local-gpu.yml
OLLAMA_PORT=11434
