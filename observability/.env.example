# Observability stack: image versions and settings
# Copy to .env. Used by docker/compose.obs.yml when run with --env-file ../observability/.env
# Run: scripts/create-env-observability.sh from repo root, or copy this file to .env

# OpenTelemetry Collector
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.102.0

# Jaeger
JAEGER_IMAGE=jaegertracing/all-in-one:1.61

# Prometheus
PROMETHEUS_IMAGE=prom/prometheus:v2.52.0

# Grafana
GRAFANA_IMAGE=grafana/grafana:11.2.0
GRAFANA_ADMIN_PASSWORD=admin

# Ports (host mapping)
JAEGER_UI_PORT=16686
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
