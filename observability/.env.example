# Observability stack: base images (used as build-args in Dockerfiles) and settings
# Copy to .env. Used by docker/compose.obs.yml when run with --env-file ../observability/.env
# Run: scripts/create-env-observability.sh from repo root, or copy this file to .env

# Base images for build (observability/Dockerfile.*)
OTEL_COLLECTOR_BASE_IMAGE=otel/opentelemetry-collector-contrib:0.102.0
JAEGER_BASE_IMAGE=jaegertracing/jaeger:2
PROMETHEUS_BASE_IMAGE=prom/prometheus:v2.52.0
GRAFANA_BASE_IMAGE=grafana/grafana:11.2.0

# Grafana
GRAFANA_ADMIN_PASSWORD=admin

# Ports (host mapping)
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROMETHEUS_SCRAPE_PORT=8889
JAEGER_UI_PORT=16686
JAEGER_COLLECTOR_PORT=14268
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
