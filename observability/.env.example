# =============================================================================
# Observability — unique source of truth for images, host ports and internal
# ports (Docker network). Generate .env: ./scripts/create-env-observability.sh
# Use with: docker compose ... --env-file ../observability/.env
# =============================================================================

# --- Base images (build-args in Dockerfiles) ---
OTEL_COLLECTOR_BASE_IMAGE=otel/opentelemetry-collector-contrib:0.102.0
JAEGER_BASE_IMAGE=jaegertracing/jaeger:2.16.0
PROMETHEUS_BASE_IMAGE=prom/prometheus:v2.52.0
GRAFANA_BASE_IMAGE=grafana/grafana:11.2.0
LOKI_BASE_IMAGE=grafana/loki:2.9.6
PROMTAIL_BASE_IMAGE=grafana/promtail:2.9.6
NODE_EXPORTER_BASE_IMAGE=prom/node-exporter:v1.7.0
CADVISOR_BASE_IMAGE=gcr.io/cadvisor/cadvisor:v0.49.1

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# --- OTEL Collector (logging exporter) ---
OTEL_COLLECTOR_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Internal ports (Docker network: service:port).
# If you change one, the Prometheus / OTLP / datasources scrape must match
# (Compose + entrypoints already propagate them).
# -----------------------------------------------------------------------------
OBS_INTERNAL_BACKEND_ACTUATOR=9000
OBS_INTERNAL_OTEL_OTLP_GRPC=4317
OBS_INTERNAL_OTEL_OTLP_HTTP=4318
OBS_INTERNAL_OTEL_PROM_EXPORT=8889
OBS_INTERNAL_PROMETHEUS=9090
OBS_INTERNAL_GRAFANA=3000
OBS_INTERNAL_JAEGER_UI=16686
OBS_INTERNAL_JAEGER_COLLECTOR_HTTP=14268
OBS_INTERNAL_JAEGER_OTLP_GRPC=4317
OBS_INTERNAL_LOKI_HTTP=3100
OBS_INTERNAL_PROMTAIL_HTTP=9080

# Collector → PostgreSQL metrics. docker-compose.yml forces OBS_PG_EXPORTER_* from db/.env POSTGRES_MONITOR_* (not from these lines).
# Keep OBS_PG_* here as documentation defaults / for non-compose runs; use the Compose service name (postgres:5432), not a container IP.
OBS_PG_ENDPOINT=postgres:5432
OBS_PG_EXPORTER_USER=postgres_exporter
OBS_PG_EXPORTER_PASSWORD=postgres_exporter
OBS_PG_DB=vectordb

# Collector → Jaeger (OTLP gRPC traces; host:port in Docker network)
OBS_OTEL_EXPORT_JAEGER_ENDPOINT=jaeger:4317

# -----------------------------------------------------------------------------
# Host ports (host:container mapping).
# The right side of the mapping must match OBS_INTERNAL_* of the service.
# -----------------------------------------------------------------------------
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROMETHEUS_SCRAPE_PORT=8889
JAEGER_UI_PORT=16686
JAEGER_COLLECTOR_PORT=14268
PROMETHEUS_PORT=9090
# Host port for Grafana UI (container listens on OBS_INTERNAL_GRAFANA; webapp uses host WEBAPP_HTTP_PORT default 80).
GRAFANA_PORT=3000

# Logs stack (docker-compose.yml, profile logs) — host optional; internals via OBS_INTERNAL_LOKI_HTTP
LOKI_HOST_PORT=3100
PROMTAIL_HOST_PORT=9080

# Infra metrics (docker-compose.yml, profiles infra / cadvisor) — host ports; base images above
NODE_EXPORTER_HOST_PORT=9100
CADVISOR_HOST_PORT=8080
