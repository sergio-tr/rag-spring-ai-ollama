auth_enabled: false

server:
  http_listen_port: __LOKI_HTTP_PORT__

common:
  path: /tmp/loki

  storage:
    filesystem:
      chunks_directory: /tmp/loki/chunks
      rules_directory: /tmp/loki/rules

schema_config:
  configs:
    - from: 2020-10-24
      store: tsdb
      object_store: filesystem
      schema: v13
      index:
        prefix: index_
        period: 24h

storage_config:
  filesystem: {}

limits_config:
  retention_period: 168h
