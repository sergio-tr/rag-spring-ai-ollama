  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Metrics from classifier-service sent via OTLP to the collector (job=otel-collector, namespace otel).",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "rate(otel_classifier_requests_total{job=\"otel-collector\"}[5m]) * 60",
          "legendFormat": "{{status}} - {{model_id}}",
          "refId": "A"
        }
      ],
      "title": "Classifier requests (OTLP)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "rate(otel_classifier_train_total{job=\"otel-collector\"}[5m]) * 60",
          "legendFormat": "{{model_id}}",
          "refId": "A"
        }
      ],
      "title": "Classifier train completions (OTLP)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "rate(otel_classifier_evaluate_total{job=\"otel-collector\"}[5m]) * 60",
          "legendFormat": "{{model_id}}",
          "refId": "A"
        }
      ],
      "title": "Classifier evaluate runs (OTLP)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "All metrics re-exported by the OTEL collector (from backend + classifier OTLP).",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "count(rate(otel_rag_query_generate_seconds_count{job=\"otel-collector\"}[5m]) > 0) or vector(0)",
          "legendFormat": "RAG query (OTLP)",
          "refId": "A"
        },
        {
          "expr": "count(rate(otel_rag_classifier_calls_total{job=\"otel-collector\"}[5m]) > 0) or vector(0)",
          "legendFormat": "Classifier calls (OTLP)",
          "refId": "B"
        }
      ],
      "title": "Backend metrics via OTLP (collector)",
      "type": "timeseries"
    }
  ],
