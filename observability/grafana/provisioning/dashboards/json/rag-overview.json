      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"backend\"}[5m])",
          "legendFormat": "{{uri}} - {{status}}",
          "refId": "A"
        },
        {
          "expr": "rate(http_server_requests_seconds_count{job=\"backend\",status=~\"5..\"}[5m])",
          "legendFormat": "5xx {{uri}} - {{status}}",
          "refId": "B"
        }
      ],
      "title": "HTTP request rate (backend)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
