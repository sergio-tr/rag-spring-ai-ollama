      "targets": [
        {
          "expr": "rate(rag_query_generate_seconds_count{job=\"backend\"}[5m]) * 60",
          "legendFormat": "{{method}} - queries/min",
          "refId": "A"
        }
      ],
      "title": "RAG query rate (backend)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(rag_query_generate_seconds_bucket{job=\"backend\"}[5m]))",
          "legendFormat": "p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(rag_query_generate_seconds_bucket{job=\"backend\"}[5m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.5, rate(rag_query_generate_seconds_bucket{job=\"backend\"}[5m]))",
          "legendFormat": "p50",
          "refId": "C"
        }
      ],
      "title": "RAG query duration (backend)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
