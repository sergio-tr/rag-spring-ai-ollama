      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "expr": "rate(rag_classifier_calls_total{job=\"backend\",status=\"success\"}[5m]) * 60",
          "legendFormat": "success",
          "refId": "A"
        },
        {
          "expr": "rate(rag_classifier_calls_total{job=\"backend\",status=\"null_result\"}[5m]) * 60",
          "legendFormat": "null_result (fallback)",
          "refId": "B"
        }
      ],
      "title": "Classifier calls (backend)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
