%% C4-style system context - onboarding
%% Export: see diagram-export.md (mmdc -i context-level.mmd -o context-level.png)
flowchart TB
  subgraph actors [Actors]
    User([User])
  end

  subgraph clients [Client tier]
    Browser[Web browser]
    Webapp[Next.js webapp]
  end

  subgraph edge [Edge optional prod-style]
    Nginx[Nginx reverse proxy]
  end

  subgraph apps [Application services]
    Backend[Spring Boot rag-service]
    Classifier[FastAPI classifier-service]
  end

  subgraph persistence [Data and ML runtime]
    PG[("PostgreSQL + pgvector")]
    Ollama[Ollama HTTP API]
  end

  subgraph telemetry [Optional observability]
    OTEL[OpenTelemetry Collector]
    Jaeger[Jaeger]
    Prometheus[Prometheus]
    Grafana[Grafana]
  end

  subgraph logs_opt [Optional log pipeline]
    Loki[Loki]
    Promtail[Promtail]
  end

  User --> Browser
  Browser --> Webapp
  Webapp -->|REST JSON SSE| Nginx
  Nginx --> Backend
  Webapp -.->|dev direct optional| Backend

  Backend --> PG
  Backend -->|embeddings chat| Ollama
  Backend -->|classify lab HTTP| Classifier

  Backend -.->|OTLP gRPC HTTP| OTEL
  Classifier -.->|OTLP| OTEL
  OTEL --> Jaeger
  OTEL --> Prometheus
  Prometheus --> Grafana
  Loki --> Grafana
  Promtail -->|push| Loki
