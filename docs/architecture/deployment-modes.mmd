%% Execution modes conceptual - full command matrices live in docker/scripts/README.md
flowchart TB
  subgraph hybrid [Dev hybrid common]
    H1[Postgres in Docker]
    H2[Spring on host mvnw]
    H3[Next on host npm]
    H1 --- H2
    H2 --- H3
  end

  subgraph dev_full [Dev max infra docker/scripts up dev --all style]
    D1[Multiple compose overlays]
    D2[backend-dev webapp optional ollama obs logs infra]
    D1 --> D2
  end

  subgraph prodlocal [Prod local style]
    P1[compose.prod.yml nginx]
    P2[Internal services not all on host ports]
    P1 --> P2
  end

  hybrid -.->|same logical app| dev_full
  dev_full -.->|different packaging| prodlocal
