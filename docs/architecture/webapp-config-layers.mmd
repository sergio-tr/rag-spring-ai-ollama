%% Webapp configuration layers - build-time public env vs container listen port detail webapp README docker-compose.yml
flowchart TB
  subgraph image_build [Image build args Docker]
    A["NEXT_PUBLIC_API_BASE_URL or WEBAPP_NEXT_PUBLIC_*"]
    B["NEXT_PUBLIC_RAG_API_PREFIX default /api/v5"]
    C["NEXT_PUBLIC_TIMEZONE"]
  end

  subgraph container_run [Container runtime]
    P["PORT equals WEBAPP_CONTAINER_PORT"]
    E["webapp/.env for local dev and compose"]
  end

  FE[Next.js server and client bundle]
  image_build --> FE
  container_run --> FE
