# Database (PostgreSQL + pgvector)
# Copy to .env and adjust. Used by docker-compose (postgres + backend).
# See db/README.md

# Pinned base image for db/Dockerfile (must match .github/ci/postgres-service-image.env and verify-pinned-postgres-image.sh).
POSTGRES_BASE_IMAGE=pgvector/pgvector:0.8.2-pg16-bookworm

POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vectordb

# Read-only user for metrics collection (OpenTelemetry PostgreSQL receiver).
# Must match the credentials used in observability/otel-collector/config.yaml.
POSTGRES_MONITOR_USER=postgres_exporter
POSTGRES_MONITOR_PASSWORD=postgres_exporter
