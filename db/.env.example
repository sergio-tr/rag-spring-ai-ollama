# Database (PostgreSQL + pgvector)
# Copy to .env and adjust. Used by docker-compose (postgres + backend).
# See db/README.md

# Reference pin for manual `docker build` / docs (must match .github/ci/postgres-service-image.env).
# docker-compose.yml passes the same pin as a fixed build-arg for service `postgres` (this value is not read by Compose for that build).
POSTGRES_BASE_IMAGE=pgvector/pgvector:0.8.2-pg16-bookworm

POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=vectordb

# Read-only user for metrics collection (OpenTelemetry PostgreSQL receiver).
# Must match OBS_PG_EXPORTER_USER / OBS_PG_EXPORTER_PASSWORD in observability/.env (docker-compose prefers these for the collector).
POSTGRES_MONITOR_USER=postgres_exporter
POSTGRES_MONITOR_PASSWORD=postgres_exporter
