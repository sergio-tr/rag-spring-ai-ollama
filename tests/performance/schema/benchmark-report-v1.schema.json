{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/benchmark-report-v1.schema.json",
  "title": "RAG micro-benchmark report",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "generatedAt", "benchmarkFamily", "transport", "summary"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "host": { "type": "string" },
    "benchmarkFamily": {
      "type": "string",
      "enum": ["retrieval", "llm"]
    },
    "transport": {
      "type": "string",
      "enum": ["legacy", "product_chat"]
    },
    "scenario": {
      "type": "object",
      "additionalProperties": true
    },
    "api": {
      "type": "object",
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": ["totalRequests", "okRequests", "errorRate"],
      "properties": {
        "totalRequests": { "type": "integer", "minimum": 0 },
        "okRequests": { "type": "integer", "minimum": 0 },
        "errorRate": { "type": "number" },
        "durationWindowSeconds": { "type": "number" },
        "throughputBenchmarkRps": { "type": "number" },
        "kpisMs": {
          "type": "object",
          "properties": {
            "p50": { "type": "number" },
            "p95": { "type": "number" },
            "p99": { "type": "number" },
            "avg": { "type": "number" }
          }
        }
      }
    },
    "tokenEstimates": {
      "type": "object",
      "properties": {
        "method": { "type": "string" },
        "estimated": { "const": true },
        "aggregate": {
          "type": "object",
          "additionalProperties": { "type": "number" }
        }
      }
    },
    "costEstimateUsd": {
      "type": ["object", "null"],
      "properties": {
        "estimated": { "type": "boolean" },
        "total": { "type": "number" },
        "pricingSource": { "type": "string" }
      }
    },
    "requests": { "type": "array" }
  }
}
